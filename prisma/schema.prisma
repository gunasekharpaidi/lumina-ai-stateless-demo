// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique

  // Plan & Credits
  plan           Plan     @default(FREE)
  credits        Int      @default(10)   // Current credits available
  totalCredits   Int      @default(10)   // Total credits for their plan per cycle
  creditsResetAt DateTime @default(now()) // When credits were last reset

  // Stripe / Payment (ready for future integration)
  stripeCustomerId       String? @unique
  stripeSubscriptionId   String? @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generations Generation[]
  creditLogs  CreditLog[]
}

model Generation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category  String        // e.g. "Apparel", "Jewellery"
  prompt    String?       @db.Text
  inputUrl  String
  outputUrl String?
  status    String        @default("queued") // queued, processing, completed, failed

  createdAt DateTime @default(now())
}

// Audit log for every credit transaction
model CreditLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Int     // positive = added, negative = spent
  description String  // e.g. "AI Generation", "Starter Plan Purchase", "Admin Grant"
  balanceAfter Int    // snapshot of credits after this transaction

  createdAt DateTime @default(now())
}
